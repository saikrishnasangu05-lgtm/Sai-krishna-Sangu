  { label: "Who are you?",     value: "who are you",      emoji: "🤖" },
  { label: "What can you do?", value: "what can you do",  emoji: "💡" },
  { label: "Who made you?",    value: "who made you",     emoji: "👨‍💻" },
  { label: "Tell me a joke",   value: "tell me a joke",   emoji: "😂" },
  { label: "Give me a quote",  value: "give me a quote",  emoji: "📜" },
  { label: "Motivate me",      value: "motivate me",      emoji: "🚀" },
